# ── Required (pick at least one) ──────────────────────────────────────────────

# Groq — FREE, no credit card, 14,400 requests/day free tier
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# OpenAI — optional, used as Whisper fallback if no Groq key
# OPENAI_API_KEY=sk-...

# Anthropic — optional
# ANTHROPIC_API_KEY=sk-ant-...

# ── Model selection ────────────────────────────────────────────────────────────
# Groq free models (fastest):
#   groq/llama-3.3-70b-versatile   ← default, best quality
#   groq/llama-3.1-8b-instant      ← fastest, lightest
#   groq/mixtral-8x7b-32768        ← good for long context
#   groq/gemma2-9b-it              ← Google Gemma
# OpenAI models (paid):
#   openai/gpt-4o-mini
#   openai/gpt-4o
MODEL=groq/llama-3.3-70b-versatile

# ── Memory backend: redis | chroma | inmem ─────────────────────────────────────
MEMORY_BACKEND=inmem        # Change to 'redis' for production persistence

# Redis connection (used when MEMORY_BACKEND=redis)
REDIS_URL=redis://localhost:6379

# ChromaDB persist directory (used when MEMORY_BACKEND=chroma)
CHROMA_PERSIST_DIR=./chroma_data

# ── Frontend → backend URL ─────────────────────────────────────────────────────
API_URL=http://localhost:8000

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=custom-memory-agent
# LANGCHAIN_TRACING_V2=true
